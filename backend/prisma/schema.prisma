generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  resource   String
  resourceId Int
  details    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ActivityLog_userId_fkey")

  @@index([userId], map: "ActivityLog_userId_fkey")
  @@map("activitylog")
}

model AuditTrail {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String   // CREATE, UPDATE, APPROVE, REJECT, DELETE
  tableName  String   // Prf, Rfp, TripTicket
  recordId   Int
  oldValues  Json?    // Snapshot of record BEFORE mutation
  newValues  Json?    // Snapshot of record AFTER mutation
  ipAddress  String?
  createdAt  DateTime @default(now())

  hash       String?
  previousHash String?

  @@index([userId])
  @@map("audittrail")
}

model Driver {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   @default("Active")
  createdAt DateTime @default(now())
  @@map("driver")
}

model Prf {
  id               Int       @id @default(autoincrement())
  prfNo            String?
  dateRequested    DateTime? @default(now())
  dateNeeded       DateTime?
  to               String?
  from             String?
  remarks          String?
  quotationSummary String?
  preparedById     Int?
  preparedBy       User?     @relation("PrfPreparedBy", fields: [preparedById], references: [id])
  verifiedById     Int?
  verifiedBy       User?     @relation("PrfVerifiedBy", fields: [verifiedById], references: [id])
  notedById        Int?
  notedBy          User?     @relation("PrfNotedBy", fields: [notedById], references: [id])
  approvedById     Int?
  approvedBy       User?     @relation("PrfApprovedBy", fields: [approvedById], references: [id])
  createdAt        DateTime  @default(now())
  layout           String?   @db.LongText
  status           String    @default("Pending")
  authorId         Int?
  requestorId      Int?
  requestor        User?     @relation("PrfRequestor", fields: [requestorId], references: [id])
  department       String?
  company          String?
  archivedById     Int?
  archivedBy       User?     @relation("PrfArchivedBy", fields: [archivedById], references: [id])
  disapprovalReason String?
  author           User?     @relation("PrfAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  items            PrfItem[]
  @@index([authorId])
  @@map("prf")
}

model PrfItem {
  id              Int     @id @default(autoincrement())
  qty             String?
  unit            String?
  particulars     String?
  estimatedCost   String?
  availableStocks String?
  prfId           Int
  prf             Prf     @relation(fields: [prfId], references: [id], onDelete: Cascade, map: "PrfItem_prfId_fkey")

  @@index([prfId], map: "PrfItem_prfId_fkey")
  @@map("prfitem")
}

model Reminder {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime
  text      String   @db.Text
  createdAt DateTime @default(now())
  endDate   DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Reminder_userId_fkey")

  @@index([userId], map: "Reminder_userId_fkey")
  @@map("reminder")
}

model Rfp {
  id            Int       @id @default(autoincrement())
  rfpNo         String?
  requestorId   Int?
  requestor     User?     @relation("RfpRequestor", fields: [requestorId], references: [id])
  dateRequested DateTime? @default(now())
  dateNeeded    DateTime?
  to            String?
  from          String?
  department    String?
  company       String?
  remarks       String?
  preparedById  Int?
  preparedBy    User?     @relation("RfpPreparedBy", fields: [preparedById], references: [id])
  verifiedById  Int?
  verifiedBy    User?     @relation("RfpVerifiedBy", fields: [verifiedById], references: [id])
  approvedById  Int?
  approvedBy    User?     @relation("RfpApprovedBy", fields: [approvedById], references: [id])
  layout        String?   @db.LongText
  status        String    @default("Pending")
  authorId      Int?
  createdAt     DateTime  @default(now())
  archivedById  Int?
  archivedBy    User?     @relation("RfpArchivedBy", fields: [archivedById], references: [id])
  receivedBy    String?
  receivedDate  DateTime?
  disapprovalReason String?
  author           User?     @relation("RfpAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  items         RfpItem[]

  @@index([authorId])
  @@map("rfp")
}

model RfpItem {
  id            Int     @id @default(autoincrement())
  qty           String?
  unit          String?
  particulars   String?
  estimatedCost String?
  availableStocks String?
  rfpId         Int
  rfp           Rfp     @relation(fields: [rfpId], references: [id], onDelete: Cascade, map: "RfpItem_rfpId_fkey")

  @@index([rfpId], map: "RfpItem_rfpId_fkey")
  @@map("rfpitem")
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  completed   Boolean  @default(false)
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Task_userId_fkey")

  @@index([userId], map: "Task_userId_fkey")
  @@map("task")
}

model TripTicket {
  id                Int      @id @default(autoincrement())
  dateRequested     DateTime? @default(now())
  requestorId       Int?
  requestor         User?    @relation("TripTicketRequestor", fields: [requestorId], references: [id])
  subsidiary        String?
  driverId          Int?
  driverUser        User?    @relation("TripTicketDriver", fields: [driverId], references: [id])
  vehicle           String?
  vehicleId         Int?
  vehicleRef        Vehicle? @relation(fields: [vehicleId], references: [id])
  plateNumber       String?
  etdOffice         String?
  etaDestination    String?
  dateTimeDeparture DateTime?
  dateTimeReturn    DateTime?
  passengersDetail  String?
  destination       String?
  purpose           String?
  medium            String?
  requestedById     Int?
  requestedBy       User?    @relation("TripTicketRequestedBy", fields: [requestedById], references: [id])
  endorsedById      Int?
  endorsedBy        User?    @relation("TripTicketEndorsedBy", fields: [endorsedById], references: [id])
  approvedById      Int?
  approvedBy        User?    @relation("TripTicketApprovedBy", fields: [approvedById], references: [id])
  createdAt         DateTime @default(now())
  layout            String?  @db.LongText
  status            String   @default("Pending")
  authorId          Int?
  guardInId         Int?
  guardInUser       User?    @relation("TripTicketGuardIn", fields: [guardInId], references: [id])
  guardOutId        Int?
  guardOutUser      User?    @relation("TripTicketGuardOut", fields: [guardOutId], references: [id])
  kmIn              String?
  kmOut             String?
  hdiPassengers     String?
  outsidePassengers String?
  passengerCount    String?
  archivedById      Int?
  archivedBy        User?    @relation("TripTicketArchivedBy", fields: [archivedById], references: [id])
  disapprovalReason String?
  author            User?    @relation("TripTicketAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@map("tripticket")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique(map: "User_email_key")
  password     String
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  canApprove          Boolean       @default(false)
  canApprovePRF       Boolean       @default(false)
  canApproveTripTicket Boolean      @default(false)
  canApproveRFP       Boolean       @default(false)
  canApproveDeptHead  Boolean       @default(false)
  canEndorse          Boolean       @default(false)
  canVerify           Boolean       @default(false)
  signatureUrl String?
  avatarUrl    String?
  themeColor   String?       @default("#0f172a")
  isDarkMode   Boolean       @default(false)
  role         UserRole      @default(User)
  status       String        @default("Active")
  inactiveReason String?     @db.Text
  companyId    Int?
  company      Company?      @relation(fields: [companyId], references: [id])
  departmentId Int?
  department   Department?   @relation(fields: [departmentId], references: [id])
  departmentRole DepartmentRole?
  isDriver     Boolean       @default(false)
  isRFPApprover Boolean      @default(false)
  isSecurityGuard  Boolean  @default(false)
  isITSpecialist   Boolean  @default(false)
  permissions  Json?
  
  // Backwards relations
  activitylog  ActivityLog[]
  auditTrails  AuditTrail[]
  reminder     Reminder[]
  task         Task[]
  notifications Notification[]
  supportTickets SupportTicket[] @relation("SupportAuthor")
  assignedSupportTickets SupportTicket[] @relation("SupportAssigned")
  resolvedSupportTickets SupportTicket[] @relation("SupportResolvedBy")
  supportMessages SupportMessage[]

  // Prf
  prfAuthors          Prf[] @relation("PrfAuthor")
  prfPrepared         Prf[] @relation("PrfPreparedBy")
  prfVerified         Prf[] @relation("PrfVerifiedBy")
  prfNoted            Prf[] @relation("PrfNotedBy")
  prfApproved         Prf[] @relation("PrfApprovedBy")
  prfArchived         Prf[] @relation("PrfArchivedBy")
  prfRequested        Prf[] @relation("PrfRequestor")

  // Rfp
  rfpAuthors          Rfp[] @relation("RfpAuthor")
  rfpPrepared         Rfp[] @relation("RfpPreparedBy")
  rfpVerified         Rfp[] @relation("RfpVerifiedBy")
  rfpApproved         Rfp[] @relation("RfpApprovedBy")
  rfpArchived         Rfp[] @relation("RfpArchivedBy")
  rfpRequested        Rfp[] @relation("RfpRequestor")

  // TripTicket
  ticketAuthors       TripTicket[] @relation("TripTicketAuthor")
  ticketRequested     TripTicket[] @relation("TripTicketRequestedBy")
  ticketEndorsed      TripTicket[] @relation("TripTicketEndorsedBy")
  ticketApproved      TripTicket[] @relation("TripTicketApprovedBy")
  ticketArchived      TripTicket[] @relation("TripTicketArchivedBy")
  ticketGuardIn       TripTicket[] @relation("TripTicketGuardIn")
  ticketGuardOut      TripTicket[] @relation("TripTicketGuardOut")
  ticketDrivers       TripTicket[] @relation("TripTicketDriver")
  ticketRequestors    TripTicket[] @relation("TripTicketRequestor")

  @@map("user")
}

model SupportTicket {
  id          Int      @id @default(autoincrement())
  subject     String
  description String?  @db.Text
  status      String   @default("Pending")
  priority    String   @default("Medium")
  category    String   @default("Others")
  authorId    Int
  author      User     @relation("SupportAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  assignedToId Int?
  assignedTo  User?    @relation("SupportAssigned", fields: [assignedToId], references: [id])
  resolvedById Int?
  resolvedBy  User?    @relation("SupportResolvedBy", fields: [resolvedById], references: [id])
  resolutionNotes String? @db.Text
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  messages    SupportMessage[]

  @@map("supportticket")
}

model Vehicle {
  id            Int      @id @default(autoincrement())
  name          String
  plateNumber   String
  brand         String?
  model         String?
  year          String?
  color         String?
  fuelType      String?
  transmission  String?
  engineNumber  String?
  chassisNumber String?
  capacity      Int
  status        String   @default("Active")
  createdAt     DateTime @default(now())
  companyId     Int?
  company       Company?  @relation(fields: [companyId], references: [id])
  departmentId  Int?
  department    Department?  @relation(fields: [departmentId], references: [id])
  tripTickets   TripTicket[]
  @@map("vehicle")
}

model SupportMessage {
  id          Int      @id @default(autoincrement())
  ticketId    Int
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    Int
  sender      User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  message     String   @db.Text
  createdAt   DateTime @default(now())

  @@map("supportmessage")
}

model Notification {
  id          Int      @id @default(autoincrement())
  message     String
  type        String   @default("INFO")
  link        String?
  isRead      Boolean  @default(false)
  targetRole  String?
  targetUserId Int?
  user        User?    @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([targetUserId])
  @@map("notification")
}

enum UserRole {
  User
  Admin
  Driver
  Guard
  Accounting
  IT
  @@map("user_role")
}

enum DepartmentRole {
  President
  DepartmentHead
  ImmediateSupervisor
  Staff
  @@map("department_role")
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isAdmin   Boolean  @default(false)
  status    String   @default("Active")
  createdAt DateTime @default(now())
  users     User[]
  vehicles  Vehicle[]

  @@map("department")
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  logoUrl   String?
  status    String   @default("Active")
  createdAt DateTime @default(now())
  users     User[]
  vehicles  Vehicle[]

  @@map("company")
}
