# Copy this to .env and fill in values for Render deployment

PORT=5000
NODE_ENV=production

# Your cloud MySQL connection string (from Aiven, PlanetScale, etc.)
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE

# Your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app

# JWT Secret (keep this the same as your current one)
JWT_SECRET=your_jwt_secret_here
