generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  resource   String
  resourceId Int
  details    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ActivityLog_userId_fkey")

  @@index([userId], map: "ActivityLog_userId_fkey")
  @@map("activitylog")
}

model Driver {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   @default("Active")
  createdAt DateTime @default(now())
  @@map("driver")
}

model Prf {
  id               Int       @id @default(autoincrement())
  prfNo            String?
  dateRequested    String?
  dateNeeded       String?
  to               String?
  from             String?
  remarks          String?
  quotationSummary String?
  preparedBy       String?
  verifiedBy       String?
  notedBy          String?
  approvedBy       String?
  createdAt        DateTime  @default(now())
  layout           String?   @db.LongText
  status           String    @default("Pending")
  authorId         Int?
  requestor        String?
  archivedBy       String?
  disapprovalReason String?
  author           User?     @relation(fields: [authorId], references: [id], onDelete: Cascade, map: "Prf_authorId_fkey")
  items            PrfItem[]
  @@index([authorId], map: "Prf_authorId_fkey")
  @@map("prf")
}

model PrfItem {
  id              Int     @id @default(autoincrement())
  qty             String?
  unit            String?
  particulars     String?
  estimatedCost   String?
  availableStocks String?
  prfId           Int
  prf             Prf     @relation(fields: [prfId], references: [id], onDelete: Cascade, map: "PrfItem_prfId_fkey")

  @@index([prfId], map: "PrfItem_prfId_fkey")
  @@map("prfitem")
}

model Reminder {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      String
  text      String   @db.Text
  createdAt DateTime @default(now())
  endDate   String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Reminder_userId_fkey")

  @@index([userId], map: "Reminder_userId_fkey")
  @@map("reminder")
}

model Rrf {
  id            Int       @id @default(autoincrement())
  rrfNo         String?
  requestor     String?
  dateRequested String?
  dateNeeded    String?
  to            String?
  from          String?
  department    String?
  company       String?
  remarks       String?
  preparedBy    String?
  verifiedBy    String?
  approvedBy    String?
  layout        String?   @db.LongText
  status        String    @default("Pending")
  authorId      Int?
  createdAt     DateTime  @default(now())
  archivedBy    String?
  receivedBy    String?
  receivedDate  String?
  disapprovalReason String?
  author           User?     @relation(fields: [authorId], references: [id], onDelete: Cascade, map: "Rrf_authorId_fkey")
  items         RrfItem[]

  @@index([authorId], map: "Rrf_authorId_fkey")
  @@map("rrf")
}

model RrfItem {
  id            Int     @id @default(autoincrement())
  qty           String?
  unit          String?
  particulars   String?
  estimatedCost String?
  availableStocks String?
  rrfId         Int
  rrf           Rrf     @relation(fields: [rrfId], references: [id], onDelete: Cascade, map: "RrfItem_rrfId_fkey")

  @@index([rrfId], map: "RrfItem_rrfId_fkey")
  @@map("rrfitem")
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  completed   Boolean  @default(false)
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Task_userId_fkey")

  @@index([userId], map: "Task_userId_fkey")
  @@map("task")
}

model TripTicket {
  id                Int      @id @default(autoincrement())
  dateRequested     String?
  requestorName     String?
  subsidiary        String?
  driver            String?
  vehicle           String?
  plateNumber       String?
  etdOffice         String?
  etaDestination    String?
  dateTimeDeparture String?
  dateTimeReturn    String?
  passengersDetail  String?
  destination       String?
  purpose           String?
  medium            String?
  requestedBy       String?
  endorsedBy        String?
  approvedBy        String?
  createdAt         DateTime @default(now())
  layout            String?  @db.LongText
  status            String   @default("Pending")
  authorId          Int?
  guardIn           String?
  guardOut          String?
  kmIn              String?
  kmOut             String?
  hdiPassengers     String?
  outsidePassengers String?
  passengerCount    String?
  archivedBy        String?
  disapprovalReason String?
  author            User?    @relation(fields: [authorId], references: [id], onDelete: Cascade, map: "TripTicket_authorId_fkey")

  @@index([authorId], map: "TripTicket_authorId_fkey")
  @@map("tripticket")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique(map: "User_email_key")
  password     String
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  canApprove          Boolean       @default(false)
  canApprovePRF       Boolean       @default(false)
  canApproveTripTicket Boolean      @default(false)
  canApproveRFP       Boolean       @default(false)
  canApproveDeptHead  Boolean       @default(false)
  canEndorse          Boolean       @default(false)
  canVerify           Boolean       @default(false)
  signatureUrl String?
  avatarUrl    String?
  themeColor   String?       @default("#6366f1")
  isDarkMode   Boolean       @default(false)
  role         UserRole      @default(User)
  permissions  Json?
  activitylog  ActivityLog[]
  prf          Prf[]
  reminder     Reminder[]
  rrf          Rrf[]
  task         Task[]
  tripticket   TripTicket[]
  @@map("user")
}

model Vehicle {
  id          Int      @id @default(autoincrement())
  name        String
  plateNumber String
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  @@map("vehicle")
}

enum UserRole {
  User
  Admin
  Driver
  Guard
  Accounting
  @@map("user_role")
}
