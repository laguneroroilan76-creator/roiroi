generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  resource   String
  resourceId Int
  details    String? 
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "ActivityLog_userId_fkey")
  @@map("activitylog")
}

model AuditTrail {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String   // CREATE, UPDATE, APPROVE, REJECT, DELETE
  tableName  String   // Prf, Rfp, TripTicket
  recordId   Int
  oldValues  Json?    // Snapshot of record BEFORE mutation
  newValues  Json?    // Snapshot of record AFTER mutation
  ipAddress  String?
  createdAt  DateTime @default(now()) @map("created_at")

  hash       String?
  previousHash String?

  @@index([userId])
  @@map("audittrail")
}

model Driver {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   @default("Active")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("driver")
}

model Prf {
  id               Int       @id @default(autoincrement())
  prfNo            String?   @map("prf_no")
  dateRequested    DateTime? @default(now()) @map("date_requested")
  dateNeeded       DateTime? @map("date_needed")
  to               String?
  from             String?
  remarks          String?
  quotationSummary String?  @map("quotation_summary")
  preparedById     Int?
  preparedBy       User?     @relation("PrfPreparedBy", fields: [preparedById], references: [id])
  verifiedById     Int?
  verifiedBy       User?     @relation("PrfVerifiedBy", fields: [verifiedById], references: [id])
  notedById        Int?
  notedBy          User?     @relation("PrfNotedBy", fields: [notedById], references: [id])
  approvedById     Int?
  approvedBy       User?     @relation("PrfApprovedBy", fields: [approvedById], references: [id])
  createdAt        DateTime  @default(now()) @map("created_at")
  layout           String?
  status           String    @default("Pending")
  authorId         Int?      @map("author_id")
  requestorId      Int?      @map("requestor_id")
  requestor        User?     @relation("PrfRequestor", fields: [requestorId], references: [id])
  department       String?
  company          String?
  archivedById     Int?      @map("archived_by_id")
  archivedBy       User?     @relation("PrfArchivedBy", fields: [archivedById], references: [id])
  disapprovalReason String?  @map("disapproval_reason")
  author           User?     @relation("PrfAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  items            PrfItem[]
  @@index([authorId])
  @@map("prf")
}

model PrfItem {
  id              Int     @id @default(autoincrement())
  qty             String?
  unit            String?
  particulars     String?
  estimatedCost   String? @map("estimated_cost")
  availableStocks String? @map("available_stocks")
  prfId           Int     @map("prf_id")
  prf             Prf     @relation(fields: [prfId], references: [id], onDelete: Cascade)

  @@index([prfId], map: "PrfItem_prfId_fkey")
  @@map("prfitem")
}

model Reminder {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  date      DateTime @map("date")
  text      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  endDate   DateTime? @map("end_date")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Reminder_userId_fkey")
  @@map("reminder")
}

model Rfp {
  id            Int       @id @default(autoincrement())
  rfpNo         String?   @map("rfp_no")
  requestorId   Int?      @map("requestor_id")
  requestor     User?     @relation("RfpRequestor", fields: [requestorId], references: [id])
  dateRequested DateTime? @default(now()) @map("date_requested")
  dateNeeded    DateTime? @map("date_needed")
  to            String?
  from          String?
  department    String?
  company       String?
  remarks       String?
  preparedById  Int?      @map("prepared_by_id")
  preparedBy    User?     @relation("RfpPreparedBy", fields: [preparedById], references: [id])
  verifiedById  Int?      @map("verified_by_id")
  verifiedBy    User?     @relation("RfpVerifiedBy", fields: [verifiedById], references: [id])
  approvedById  Int?      @map("approved_by_id")
  approvedBy    User?     @relation("RfpApprovedBy", fields: [approvedById], references: [id])
  layout        String?
  status        String    @default("Pending")
  authorId      Int?      @map("author_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  archivedById  Int?      @map("archived_by_id")
  archivedBy    User?     @relation("RfpArchivedBy", fields: [archivedById], references: [id])
  receivedBy    String?   @map("received_by")
  receivedDate  DateTime? @map("received_date")
  disapprovalReason String? @map("disapproval_reason")
  author           User?     @relation("RfpAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  items         RfpItem[]

  @@index([authorId])
  @@map("rfp")
}

model RfpItem {
  id            Int     @id @default(autoincrement())
  qty           String?
  unit          String?
  particulars   String?
  estimatedCost String? @map("estimated_cost")
  availableStocks String? @map("available_stocks")
  rfpId         Int     @map("rfp_id")
  rfp           Rfp     @relation(fields: [rfpId], references: [id], onDelete: Cascade)

  @@index([rfpId], map: "RfpItem_rfpId_fkey")
  @@map("rfpitem")
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  completed   Boolean  @default(false)
  userId      Int      @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Task_userId_fkey")
  @@map("task")
}

model TripTicket {
  id                Int      @id @default(autoincrement())
  dateRequested     DateTime? @default(now()) @map("date_requested")
  requestorId       Int?      @map("requestor_id")
  requestor         User?    @relation("TripTicketRequestor", fields: [requestorId], references: [id])
  subsidiary        String?
  driverId          Int?      @map("driver_id")
  driverUser        User?    @relation("TripTicketDriver", fields: [driverId], references: [id])
  vehicle           String?
  vehicleId         Int?      @map("vehicle_id")
  vehicleRef        Vehicle? @relation(fields: [vehicleId], references: [id])
  plateNumber       String?   @map("plate_number")
  etdOffice         String?   @map("etd_office")
  etaDestination    String?   @map("eta_destination")
  dateTimeDeparture DateTime? @map("date_time_departure")
  dateTimeReturn    DateTime? @map("date_time_return")
  passengersDetail  String?   @map("passengers_detail")
  destination       String?
  purpose           String?
  medium            String?
  requestedById     Int?      @map("requested_by_id")
  requestedBy       User?    @relation("TripTicketRequestedBy", fields: [requestedById], references: [id])
  endorsedById      Int?      @map("endorsed_by_id")
  endorsedBy        User?    @relation("TripTicketEndorsedBy", fields: [endorsedById], references: [id])
  approvedById      Int?      @map("approved_by_id")
  approvedBy        User?    @relation("TripTicketApprovedBy", fields: [approvedById], references: [id])
  createdAt         DateTime @default(now()) @map("created_at")
  layout            String?
  status            String   @default("Pending")
  authorId          Int?      @map("author_id")
  guardInId         Int?      @map("guard_in_id")
  guardInUser       User?    @relation("TripTicketGuardIn", fields: [guardInId], references: [id])
  guardOutId        Int?      @map("guard_out_id")
  guardOutUser      User?    @relation("TripTicketGuardOut", fields: [guardOutId], references: [id])
  kmIn              String?   @map("km_in")
  kmOut             String?   @map("km_out")
  hdiPassengers     String?   @map("hdi_passengers")
  outsidePassengers String?   @map("outside_passengers")
  passengerCount    String?   @map("passenger_count")
  archivedById      Int?      @map("archived_by_id")
  archivedBy        User?    @relation("TripTicketArchivedBy", fields: [archivedById], references: [id])
  disapprovalReason String?   @map("disapproval_reason")
  author            User?    @relation("TripTicketAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@map("tripticket")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique(map: "User_email_key")
  password     String
  name         String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  canApprove          Boolean       @default(false)
  canApprovePRF       Boolean       @default(false)
  canApproveTripTicket Boolean      @default(false)
  canApproveRFP       Boolean       @default(false)
  canApproveDeptHead  Boolean       @default(false)
  canEndorse          Boolean       @default(false)
  canVerify           Boolean       @default(false)
  signatureUrl String?
  avatarUrl    String?
  themeColor   String?       @default("#0f172a")
  isDarkMode   Boolean       @default(false)
  role         UserRole      @default(User)
  status       String        @default("Active")
  inactiveReason String?     @db.Text @map("inactive_reason")
  companyId    Int?          @map("company_id")
  company      Company?      @relation(fields: [companyId], references: [id])
  departmentId Int?          @map("department_id")
  department   Department?   @relation(fields: [departmentId], references: [id])
  departmentRole DepartmentRole? @map("department_role")
  isDriver     Boolean       @default(false)
  isRFPApprover Boolean      @default(false)
  isSecurityGuard  Boolean  @default(false)
  isITSpecialist   Boolean  @default(false)
  permissions  Json?
  
  // Backwards relations
  activitylog  ActivityLog[]
  auditTrails  AuditTrail[]
  reminder     Reminder[]
  task         Task[]
  notifications Notification[]
  supportTickets SupportTicket[] @relation("SupportAuthor")
  assignedSupportTickets SupportTicket[] @relation("SupportAssigned")
  resolvedSupportTickets SupportTicket[] @relation("SupportResolvedBy")
  supportMessages SupportMessage[]

  // Prf
  prfAuthors          Prf[] @relation("PrfAuthor")
  prfPrepared         Prf[] @relation("PrfPreparedBy")
  prfVerified         Prf[] @relation("PrfVerifiedBy")
  prfNoted            Prf[] @relation("PrfNotedBy")
  prfApproved         Prf[] @relation("PrfApprovedBy")
  prfArchived         Prf[] @relation("PrfArchivedBy")
  prfRequested        Prf[] @relation("PrfRequestor")

  // Rfp
  rfpAuthors          Rfp[] @relation("RfpAuthor")
  rfpPrepared         Rfp[] @relation("RfpPreparedBy")
  rfpVerified         Rfp[] @relation("RfpVerifiedBy")
  rfpApproved         Rfp[] @relation("RfpApprovedBy")
  rfpArchived         Rfp[] @relation("RfpArchivedBy")
  rfpRequested        Rfp[] @relation("RfpRequestor")

  // TripTicket
  ticketAuthors       TripTicket[] @relation("TripTicketAuthor")
  ticketRequested     TripTicket[] @relation("TripTicketRequestedBy")
  ticketEndorsed      TripTicket[] @relation("TripTicketEndorsedBy")
  ticketApproved      TripTicket[] @relation("TripTicketApprovedBy")
  ticketArchived      TripTicket[] @relation("TripTicketArchivedBy")
  ticketGuardIn       TripTicket[] @relation("TripTicketGuardIn")
  ticketGuardOut      TripTicket[] @relation("TripTicketGuardOut")
  ticketDrivers       TripTicket[] @relation("TripTicketDriver")
  ticketRequestors    TripTicket[] @relation("TripTicketRequestor")

  @@map("user")
}

model SupportTicket {
  id          Int      @id @default(autoincrement())
  subject     String
  description String?  @db.Text
  status      String   @default("Pending")
  priority    String   @default("Medium")
  category    String   @default("Others")
  authorId    Int      @map("author_id")
  author      User     @relation("SupportAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  assignedToId Int?     @map("assigned_to_id")
  assignedTo  User?    @relation("SupportAssigned", fields: [assignedToId], references: [id])
  resolvedById Int?     @map("resolved_by_id")
  resolvedBy  User?    @relation("SupportResolvedBy", fields: [resolvedById], references: [id])
  resolutionNotes String? @db.Text @map("resolution_notes")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  messages    SupportMessage[]

  @@map("supportticket")
}

model Vehicle {
  id            Int      @id @default(autoincrement())
  name          String
  plateNumber   String   @map("plate_number")
  brand         String?
  model         String?
  year          String?
  color         String?
  fuelType      String?  @map("fuel_type")
  transmission  String?
  engineNumber  String?  @map("engine_number")
  chassisNumber String?  @map("chassis_number")
  capacity      Int
  status        String   @default("Active")
  createdAt     DateTime @default(now()) @map("created_at")
  companyId     Int?      @map("company_id")
  company       Company?  @relation(fields: [companyId], references: [id])
  departmentId  Int?      @map("department_id")
  department    Department?   @relation(fields: [departmentId], references: [id])
  tripTickets   TripTicket[]
  @@map("vehicle")
}

model SupportMessage {
  id          Int          @id @default(autoincrement())
  ticketId    Int           @map("ticket_id")
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    Int           @map("sender_id")
  sender      User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  message     String        @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")

  @@map("supportmessage")
}

model Notification {
  id          Int      @id @default(autoincrement())
  message     String
  type        String   @default("INFO")
  link        String?
  isRead      Boolean  @default(false) @map("is_read")
  targetRole  String?  @map("target_role")
  targetUserId Int?     @map("target_user_id")
  user        User?    @relation(fields: [targetUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([targetUserId])
  @@map("notification")
}

enum UserRole {
  User
  Admin
  Driver
  Guard
  Accounting
  IT
  @@map("user_role")
}

enum DepartmentRole {
  President
  DepartmentHead
  ImmediateSupervisor
  Staff
  @@map("department_role")
}

model Department {
  id           Int      @id @default(autoincrement())
  name         String
  companyId    Int?      @map("company_id")
  company      Company? @relation(fields: [companyId], references: [id])
  isAdmin      Boolean  @default(false) @map("is_admin")
  isAccounting Boolean  @default(false) @map("is_accounting")
  status       String   @default("Active")
  createdAt    DateTime @default(now()) @map("created_at")
  users        User[]
  vehicles     Vehicle[]

  @@unique([name, companyId])
  @@map("department")
}

model Company {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  logoUrl      String?       @map("logo_url")
  status       String        @default("Active")
  createdAt    DateTime      @default(now()) @map("created_at")
  users        User[]
  vehicles     Vehicle[]
  departments  Department[]

  @@map("company")
}